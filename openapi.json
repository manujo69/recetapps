                    "id": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "clientId": {
                        "type": "string"
                    },
                    "recipeId": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "updatedAt": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "deletedAt": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            },
            "RecipePushItem": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "clientId": {
                        "type": "string"
                    },
                    "title": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "ingredients": {
                        "type": "string"
                    },
                    "instructions": {
                        "type": "string"
                    },
                    "prepTime": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "cookTime": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "servings": {
                        "type": "integer",
