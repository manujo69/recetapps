    "components": {
        "schemas": {
            "RecipeDTO": {
                "required": [
                    "cookTime",
                    "ingredients",
                    "instructions",
                    "prepTime",
                    "servings",
                    "title"
                ],
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "description": "Recipe ID",
                        "format": "int64",
                        "readOnly": true,
                        "example": 1
                    },
                    "title": {
                        "maxLength": 200,
                        "minLength": 0,
                        "type": "string",
                        "description": "Recipe title",
                        "example": "Spaghetti Carbonara"
                    },
                    "description": {
                        "maxLength": 1000,
                        "minLength": 0,
                        "type": "string",
                        "description": "Short description of the recipe",
                        "example": "Classic Italian pasta dish"
                    },
                    "ingredients": {
                        "type": "string",
                        "description": "List of ingredients (one per line)",
                        "example": "200g spaghetti\n100g pancetta\n2 eggs"
                    },
                    "instructions": {
                        "type": "string",
                        "description": "Step-by-step instructions",
                        "example": "1. Cook pasta\n2. Fry pancetta\n3. Mix eggs"
                    },
                    "prepTime": {
                        "type": "integer",
                        "description": "Preparation time in minutes",
                        "format": "int32",
                        "example": 15
                    },
                    "cookTime": {
                        "type": "integer",
                        "description": "Cooking time in minutes",
                        "format": "int32",
                        "example": 20
                    },
                    "servings": {
                        "type": "integer",
                        "description": "Number of servings",
                        "format": "int32",
                        "example": 4
                    },
                    "categoryIds": {
                        "type": "array",
                        "description": "IDs of the categories this recipe belongs to",
                        "example": [
                            2,
                            5
                        ],
                        "items": {
                            "type": "integer",
                            "description": "IDs of the categories this recipe belongs to",
                            "format": "int64"
                        }
                    },
                    "categoryNames": {
                        "type": "array",
                        "description": "Category names (populated on read)",
                        "readOnly": true,
                        "example": [
                            "Pasta",
                            "Italian"
                        ],
                        "items": {
                            "type": "string",
                            "description": "Category names (populated on read)",
                            "readOnly": true,
                            "example": "[\"Pasta\",\"Italian\"]"
                        }
                    },
                    "userId": {
                        "type": "integer",
                        "description": "ID of the user who created the recipe",
                        "format": "int64",
                        "readOnly": true,
                        "example": 1
                    },
                    "username": {
                        "type": "string",
                        "description": "Username of the creator",
                        "readOnly": true,
                        "example": "john_doe"
                    },
                    "images": {
                        "type": "array",
                        "description": "Images attached to this recipe",
                        "readOnly": true,
                        "items": {
                            "$ref": "#/components/schemas/RecipeImageDTO"
                        }
                    },
                    "createdAt": {
                        "type": "string",
                        "description": "Creation timestamp",
                        "format": "date-time",
                        "readOnly": true
                    },
                    "updatedAt": {
                        "type": "string",
                        "description": "Last update timestamp",
                        "format": "date-time",
                        "readOnly": true
                    },
                    "deletedAt": {
                        "type": "string",
                        "description": "Soft delete timestamp, null if active",
                        "format": "date-time",
                        "readOnly": true
                    }
                },
                "description": "Recipe data including ingredients, instructions and metadata"
            },
            "RecipeImageDTO": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "description": "Image ID",
                        "format": "int64",
                        "readOnly": true,
                        "example": 1
                    },
                    "filename": {
                        "type": "string",
                        "description": "Stored filename",
                        "readOnly": true,
                        "example": "abc123.jpg"
                    },
                    "url": {
                        "type": "string",
                        "description": "Public URL to access the image",
                        "readOnly": true,
                        "example": "http://localhost:8080/recipes/1/images/1"
                    },
                    "createdAt": {
                        "type": "string",
                        "description": "Upload timestamp",
                        "format": "date-time",
                        "readOnly": true
                    }
                },
                "description": "Image associated with a recipe",
                "readOnly": true
            },
            "Category": {
                "required": [
                    "name"
                ],
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "name": {
                        "maxLength": 100,
                        "minLength": 0,
                        "type": "string"
                    },
                    "description": {
                        "maxLength": 500,
                        "minLength": 0,
                        "type": "string"
                    },
                    "createdAt": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "updatedAt": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "deletedAt": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            },
            "CategoryPushItem": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer",
                        "format": "int64"
                    },
                    "clientId": {
                        "type": "string"
                    },
                    "name": {
                        "type": "string"
                    },
                    "description": {
                        "type": "string"
                    },
                    "updatedAt": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "deletedAt": {
                        "type": "string",
                        "format": "date-time"
                    }
                }
            },
            "FavoritePushItem": {
                "type": "object",
